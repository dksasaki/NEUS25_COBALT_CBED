#!/bin/bash

module load cmake/4.2.3

export SOFTWARE_DIR=/projects/schultz/d.sasaki/compilation/explorer/20260325_zen2_explorer
export PATH=$SOFTWARE_DIR/bin:$PATH
export LD_LIBRARY_PATH=$LD_LIBRARY_PATH:$SOFTWARE_DIR/lib:$SOFTWARE_DIR/lib64
export PKG_CONFIG_PATH=$SOFTWARE_DIR/lib/pkgconfig:$SOFTWARE_DIR/lib64/pkgconfig:$PKG_CONFIG_PATH
export CPATH=$SOFTWARE_DIR/include:$CPATH

export MPICC=$SOFTWARE_DIR/bin/mpicc
export MPICXX=$SOFTWARE_DIR/bin/mpicxx
export MPIFC=$SOFTWARE_DIR/bin/mpifort
export MPIF77=$SOFTWARE_DIR/bin/mpif77
export MPIF90=$SOFTWARE_DIR/bin/mpif90

# UCX runtime settings for ConnectX-5
export UCX_NET_DEVICES=mlx5_0:1
export UCX_TLS=rc_mlx5,ud_mlx5,self,sm
export UCX_IB_REG_METHODS=rcache
export UCX_RNDV_THRESH=8192

# OpenMPI UCX settings
export OMPI_MCA_pml=ucx
export OMPI_MCA_osc=ucx
export OMPI_MCA_btl=^vader,tcp,openib,uct
